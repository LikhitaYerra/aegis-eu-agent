# Optional: without this key, python src/agent.py runs in deterministic demo mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_INPUT_COST_PER_1M=0.40
OPENAI_OUTPUT_COST_PER_1M=1.60

# Optional Langfuse observability. All three values are required for remote traces.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Per-run hard limit used by the application-level TokenBudget.
TOKEN_BUDGET=12000
